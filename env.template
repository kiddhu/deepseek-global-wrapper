# SeekAPI / AION backend & ops — copy to your real env files; do not commit secrets.
# Fill values locally or in your process manager (systemd, Docker, Vercel, etc.).

# --- Dashboard (Flask HQ) ---
DASHBOARD_HOST=
DASHBOARD_PORT=
DASHBOARD_TOKEN=

# --- Supabase / Postgres (db_utils.py, dashboard traffic) ---
# Prefer config/supabase.env with DB_URL=postgresql://... (password URL-encoded if needed)
DB_URL=

# --- Frontend blog (Vercel / Next.js server) — optional remote posts ---
SUPABASE_URL=
# Use service role on server for private tables, or anon if RLS allows public read
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# PostgREST table name (default blog_posts)
SUPABASE_BLOG_TABLE=

# --- Scholar / content agents ---
GITHUB_TOKEN=
DEEPSEEK_API_KEY=
VERCEL_HOOK_URL=
AION_ENABLE_GIT_AUTOPUSH=

# --- Keep-alive & heartbeat (scripts/keep_alive.py) ---
AION_REPO_ROOT=
AION_DASH_SEEKAPI_URL=
AION_DASHBOARD_URL=
AION_DASHBOARD_TOKEN=
AION_ONEAPI_URL=
AION_KEEPALIVE_INTERVAL_SECONDS=
AION_ONEAPI_RESTART_CMD=

# --- SEO / GitHub / Dev.to ---
DEV_TO_API_KEY=

# --- Email ---
RESEND_API_KEY=

# --- Cloudflare ---
CF_ZONE_ID=
CF_API_TOKEN=

# --- Optional scripts ---
GITHUB_REPO=
DEEPSEEK_BASE_URL=
SEEKAPI_MASTER_KEY=
SEEKAPI_API_KEY=

